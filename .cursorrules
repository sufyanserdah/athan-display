│   ├── context/
│   │   └── SettingsContext.jsx  # Global settings state
│   ├── utils/
│   │   ├── api.js              # Aladhan API calls
│   │   └── timeUtils.js        # Time formatting/comparison helpers
│   ├── App.jsx
│   ├── main.jsx
